# ==============================================================================
# chatbot-rag-fptu - Root .gitignore
# A comprehensive gitignore for Node.js (API & Web) & Python (RAG) monorepo
# ==============================================================================

# ------------------------------------------------------------------------------
# Dependencies & Package Managers
# ------------------------------------------------------------------------------
node_modules/
jspm_packages/
web_modules/

# Yarn
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# pnpm
.pnpm-store/
store.ipfs/

# bun
bun.lockb

# ------------------------------------------------------------------------------
# Environment Variables & Secrets (CRITICAL: Do not commit sensitive data)
# ------------------------------------------------------------------------------
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local
*.env
*.pem
*.key
*.cert
*.crt
# Firebase/GCP service accounts
*-credentials.json
*.json.enc

# ------------------------------------------------------------------------------
# Next.js & Frontend Build Outputs
# ------------------------------------------------------------------------------
.next/
out/
build/
dist/
.serverless/
.sst/

# TS build info
*.tsbuildinfo

# ------------------------------------------------------------------------------
# Testing & Coverage
# ------------------------------------------------------------------------------
coverage/
.nyc_output/
html-report/
.playwright/
test-results/
playwright-report/
blob-report/

# ------------------------------------------------------------------------------
# Logs and Debug files
# ------------------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
pid
*.pid
*.seed
*.pid.lock

# ------------------------------------------------------------------------------
# IDEs, Editors & Tools
# ------------------------------------------------------------------------------
# VS Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/*.code-snippets

# JetBrains (WebStorm, IntelliJ, PyCharm, etc.)
.idea/
*.iml
*.iws
*.ipr

# OS Specific Files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Sublime Text
*.sublime-project
*.sublime-workspace

# Diagnostic reports (Common in Node.js)
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# ------------------------------------------------------------------------------
# Python & RAG (Retrieval Augmented Generation) Ecosystem
# ------------------------------------------------------------------------------
# Virtual environments
venv/
.venv/
env/
.env/
ENV/
env.bak/
venv.bak/

# Python Cache
__pycache__/
*.py[cod]
*$py.class

# Jupyter Notebooks & Data Science
.ipynb_checkpoints
.jupyter/
.python-version

# Vector DBs / Data caches
.chroma/
.faiss/
data/raw/
data/processed/
*.db
*.sqlite

# ------------------------------------------------------------------------------
# Vercel & Deployment
# ------------------------------------------------------------------------------
.vercel
.turbo
