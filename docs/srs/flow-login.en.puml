@startuml
title Authentication & Login Flow Diagram

|User|
start
:Open login page;
if (Login method?) then (Email/Password)
  :Enter email and password;
  :Submit credentials;
  |System Handler|
  :Validate credentials through Better Auth;
  if (Credentials valid?) then (Yes)
    :Create authenticated session cookie;
    |User|
    :Sign in successfully;
    :Redirect by role\n(Student / Lecturer / Admin);
  else (No)
    |System Handler|
    :Return sign-in error;
    |User|
    :Review error and retry;
  endif
else (Google SSO)
  :Click "Login with Google";
  |System Handler|
  :Redirect to Google OAuth;
  :Receive authentication result from Google;
  if (User does not exist yet?) then (Yes)
    :Auto-create account through Better Auth flow;
  endif
  :Create authenticated session cookie;
  |User|
  :Sign in successfully;
  :Redirect by role;
endif

stop
@enduml
