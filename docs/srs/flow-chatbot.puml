@startuml
title Sơ đồ quy trình trò chuyện (Chatbot Flow)

|Học sinh (Student)|
start
:Mở trang chat;
if (Đã có phiên phù hợp?) then (Chưa)
  :Chọn phạm vi chat\n(Tất cả môn / Môn đã chọn / Tài liệu đã chọn);
  :Tạo phiên chat mới;
else (Rồi)
  :Chọn phiên chat có sẵn;
endif
:Nhập và gửi câu hỏi;

|Hệ thống Chatbot|
:Gửi yêu cầu chat kèm sessionId;

|System Handler|
:Xác thực người dùng và quyền truy cập phiên chat;
:Kiểm tra quota gói hiện tại\n(số tin nhắn trong cửa sổ 5 giờ);
if (Còn quota?) then (Có)
  :Lưu tin nhắn người dùng vào lịch sử;
  if (Đây là tin nhắn đầu tiên?) then (Có)
    :Tự động sinh tiêu đề phiên chat;
  endif
  :Xác định phạm vi tài liệu áp dụng cho phiên chat;
  :Phân loại ý định câu hỏi\n(RAG hỏi đáp hay hỏi metadata tài liệu);
  if (Cần truy vấn RAG?) then (Có)
    :Tìm ngữ cảnh trong tài liệu theo phạm vi đã chọn;
    :Sinh câu trả lời và citations;
  else (Không)
    :Sinh câu trả lời metadata\n(ví dụ tài liệu nào đang có);
  endif
  :Stream câu trả lời qua SSE;
  :Lưu phản hồi trợ lý và tăng bộ đếm quota;
  |Hệ thống Chatbot|
  :Hiển thị nội dung trả lời theo thời gian thực;
  :Hiển thị citations,\nđánh dấu nguồn đã bị xóa nếu có;
  |Học sinh (Student)|
  :Đọc câu trả lời và nguồn trích dẫn;
else (Không)
  :Tạo phản hồi hết quota;
  :Stream thông báo hết quota qua SSE;
  |Hệ thống Chatbot|
  :Hiển thị thông báo chờ reset quota\nhoặc nâng cấp gói;
  |Học sinh (Student)|
  :Nhận thông báo vượt giới hạn sử dụng;
endif

stop
@enduml
