@startuml
title Sơ đồ quy trình xác thực và đăng nhập (Authentication & Login Flow)

|Người dùng (User)|
start
:Truy cập trang đăng nhập;
if (Phương thức đăng nhập?) then (Email/Password)
  :Nhập email và mật khẩu;
  :Gửi thông tin đăng nhập;
  |System Handler|
  :Xác thực thông tin qua Better Auth;
  if (Thông tin hợp lệ?) then (Có)
    :Tạo session cookie xác thực;
    |Người dùng (User)|
    :Đăng nhập thành công;
    :Được chuyển hướng theo role\n(Student / Lecturer / Admin);
  else (Không)
    |System Handler|
    :Trả lỗi đăng nhập;
    |Người dùng (User)|
    :Xem lỗi và nhập lại;
  endif
else (Google SSO)
  :Chọn "Đăng nhập với Google";
  |System Handler|
  :Chuyển hướng sang Google OAuth;
  :Nhận kết quả xác thực từ Google;
  if (Tài khoản chưa tồn tại?) then (Có)
    :Tự tạo tài khoản mới theo luồng Better Auth;
  endif
  :Tạo session cookie xác thực;
  |Người dùng (User)|
  :Đăng nhập thành công;
  :Được chuyển hướng theo role;
endif

stop
@enduml
