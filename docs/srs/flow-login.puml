@startuml
title Sơ đồ quy trình xác thực và đăng nhập (Authentication & Login Flow)

|Người dùng (User)|
start
:Truy cập trang đăng nhập;
if (Phương thức đăng nhập?) then (Email/Password)
  :Nhập Email và Mật khẩu;
  :Gửi thông tin đăng nhập;
  |System Handler|
  :Mã hóa và kiểm tra thông tin trong CSDL;
  if (Thông tin hợp lệ?) then (Có)
    :Tạo JWT Session và Cookie xác thực;
    |Người dùng (User)|
    :Đăng nhập thành công và chuyển hướng trang;
  else (Không)
    |System Handler|
    :Trả về lỗi đăng nhập;
    |Người dùng (User)|
    :Hiển thị lỗi và yêu cầu nhập lại;
  endif
else (Google SSO)
  |Người dùng (User)|
  :Chọn "Đăng nhập bằng Google";
  :Xác thực tài khoản qua Google Prompt;
  |System Handler|
  :Nhận Google Token và xác thực với Google API;
  :Kiểm tra tài khoản trong CSDL;
  if (Tài khoản đã tồn tại?) then (Chưa)
    :Tạo tài khoản học sinh (Student) mới tự động;
  else (Rồi)
  endif
  :Tạo JWT Session và Cookie xác thực;
  |Người dùng (User)|
  :Đăng nhập thành công và chuyển hướng trang;
endif

stop
@enduml
